# Inventory Service environment example
# Copy this file to .ENV or .env locally and fill in real values.
# Do not commit secrets.

# Required for database-backed mode
DATABASE_URL=postgresql://postgres:your_url_encoded_password@db.your-project.supabase.co:5432/postgres

# Required for internal auth between services
INTERNAL_API_KEY=change-me-internal-key

# Optional: Relationship API push target
RELATIONSHIP_API_URL=https://your-relationship-api.onrender.com
RELATIONSHIP_API_KEY=change-me-relationship-key

# Optional: Groq structured review layer
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional: Operational thresholds
DEFAULT_MIN_OFFICERS=9
DEFAULT_MIN_ARMED_OFFICERS=3
DEFAULT_MIN_VEHICLES=2
DEFAULT_MIN_FUELLED_VEHICLES=3
DEFAULT_VEHICLE_FUEL_THRESHOLD=30
DEFAULT_FUEL_RESERVE_LITRES=200

# Optional: Telemetry cadence defaults
DEFAULT_OFFICER_PING_SECONDS=60
DEFAULT_VEHICLE_GPS_RUNNING_SECONDS=30
DEFAULT_VEHICLE_GPS_PARKED_SECONDS=300

# Optional: Runtime environment
ENVIRONMENT=development
PORT=8000